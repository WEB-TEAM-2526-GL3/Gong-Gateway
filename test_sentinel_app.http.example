#just replace the api keys for groq and open-router
@sentinel = http://localhost:3000
@kongProxy = http://localhost:8000



### ============================================================
### AUTH VARIABLES
### ============================================================

@ceoSecret = ceo_ceo

@adminEmail = admin@sentinel.com
@adminFullName = Sentinel Admin
@adminPassword = admin123

@secondAdminEmail = second.admin@sentinel.com
@secondAdminFullName = Second Sentinel Admin
@secondAdminPassword = admin456




### ============================================================
### AUTH TESTS
### ============================================================

### 0.1) Register first admin
### Run this once. If the user already exists, skip this and run login.
# @name registerMainAdmin
POST {{sentinel}}/auth/register
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "fullName": "{{adminFullName}}",
  "password": "{{adminPassword}}",
  "ceoSecret": "{{ceoSecret}}"
}



### 0.2) Login main admin
# @name loginMainAdmin
POST {{sentinel}}/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}


### ============================================================
### GATEWAY (updated)
### ============================================================

@openrouterService = openrouter-service
@openrouterRoute = openrouter-route
@openrouterKey = *********

@groqService = groq-service
@groqRoute = groq-route
@groqKey = *********


### 1) Create OpenRouter service through Sentinel gateway controller
POST {{sentinel}}/gateway/services
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "name": "{{openrouterService}}",
  "url": "https://openrouter.ai/api"
}


### 1.1) Add OpenRouter API key to the service
POST {{sentinel}}/gateway/services/{{openrouterService}}/api-key
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "apiKey": "{{openrouterKey}}"
}


### 2) Create OpenRouter route through Sentinel gateway controller
POST {{sentinel}}/gateway/services/{{openrouterService}}/routes
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "name": "{{openrouterRoute}}",
  "paths": ["/openrouter"],
  "stripPath": true,
  "methods": ["GET", "POST", "OPTIONS"]
}


### 3) Create Groq service through Sentinel gateway controller
POST {{sentinel}}/gateway/services
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "name": "{{groqService}}",
  "url": "https://api.groq.com/openai"
}


### 3.1) Add Groq API key to the service
POST {{sentinel}}/gateway/services/{{groqService}}/api-key
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "apiKey": "{{groqKey}}"
}


### 4) Create Groq route through Sentinel gateway controller
POST {{sentinel}}/gateway/services/{{groqService}}/routes
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "name": "{{groqRoute}}",
  "paths": ["/groq"],
  "stripPath": true,
  "methods": ["GET", "POST", "OPTIONS"]
}


### 5) Verify services through Sentinel gateway controller
GET {{sentinel}}/gateway/services
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}


### 6) Verify routes through Sentinel gateway controller
GET {{sentinel}}/gateway/routes
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}


### 7) Optional: test OpenRouter route through Kong proxy (unchanged)
### With service url https://openrouter.ai/api and stripPath=true:
### /openrouter/v1/chat/completions -> https://openrouter.ai/api/v1/chat/completions
POST {{kongProxy}}/openrouter/v1/chat/completions
Content-Type: application/json

{
  "model": "openai/gpt-4o-mini",
  "messages": [
    {
      "role": "user",
      "content": "Say hello from Sentinel Gateway through OpenRouter."
    }
  ]
}


### 8) Optional: test Groq route through Kong proxy (unchanged)
### With service url https://api.groq.com/openai and stripPath=true:
### /groq/v1/chat/completions -> https://api.groq.com/openai/v1/chat/completions
POST {{kongProxy}}/groq/v1/chat/completions
Content-Type: application/json

{
  "model": "llama-3.1-8b-instant",
  "messages": [
    {
      "role": "user",
      "content": "Say hello from Sentinel Gateway through Groq."
    }
  ]
}


### 9) Optional: update OpenRouter service URL through Sentinel gateway controller
PATCH {{sentinel}}/gateway/services/{{openrouterService}}
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "url": "https://openrouter.ai/api"
}


### 10) Optional: update Groq service URL through Sentinel gateway controller
PATCH {{sentinel}}/gateway/services/{{groqService}}
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
Content-Type: application/json

{
  "url": "https://api.groq.com/openai"
}


### ============================================================
### LLM TEST VARIABLES
### ============================================================

@prompt = how are you?

### OpenRouter models
@openrouterModel1 = openai/gpt-oss-120b:free
@openrouterModel2 = openrouter/free

### Groq models
### These are Groq production model IDs.
@groqModel1 = llama-3.1-8b-instant
@groqModel2 = llama-3.3-70b-versatile


### ============================================================
POST {{kongProxy}}/openrouter/v1/chat/completions
Content-Type: application/json

{
  "model": "{{openrouterModel1}}",
  "messages": [
    {
      "role": "user",
      "content": "{{prompt}}"
    }
  ]
}


### 14) Test OpenRouter with another free model/router through Kong proxy
POST {{kongProxy}}/openrouter/v1/chat/completions
Content-Type: application/json

{
  "model": "{{openrouterModel2}}",
  "messages": [
    {
      "role": "user",
      "content": "{{prompt}}"
    }
  ]
}




### ============================================================
POST {{kongProxy}}/groq/v1/chat/completions
Content-Type: application/json

{
  "model": "{{groqModel1}}",
  "messages": [
    {
      "role": "user",
      "content": "{{prompt}}"
    }
  ]
}


### 16) Test Groq with llama-3.3-70b-versatile through Kong proxy
POST {{kongProxy}}/groq/v1/chat/completions
Content-Type: application/json

{
  "model": "{{groqModel2}}",
  "messages": [
    {
      "role": "user",
      "content": "{{prompt}}"
    }
  ]
}



### ============================================================
### DELETE TESTS
### ============================================================

### 17) Delete OpenRouter route through Sentinel gateway controller
DELETE {{sentinel}}/gateway/routes/{{openrouterRoute}}
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}


### 18) Delete Groq route through Sentinel gateway controller
DELETE {{sentinel}}/gateway/routes/{{groqRoute}}
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}


### 19) Delete OpenRouter service through Sentinel gateway controller
DELETE {{sentinel}}/gateway/services/{{openrouterService}}
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}


### 20) Delete Groq service through Sentinel gateway controller
DELETE {{sentinel}}/gateway/services/{{groqService}}
Authorization: Bearer {{loginMainAdmin.response.body.$.accessToken}}
